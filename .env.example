# ============================================================================
# MeshCentral Production Environment Variables
# Copy this file to .env and customize for your deployment
# ============================================================================

# ┌──────────────────────────────────────────────┐
# │  🌐 DOMAIN & NETWORKING                      │
# └──────────────────────────────────────────────┘

# Your MeshCentral domain (REQUIRED — change this!)
MC_HOSTNAME=mesh.yourdomain.com

# External port mapping (443 for production)
MC_EXTERNAL_PORT=443

# Set to true when behind a reverse proxy (Coolify/Traefik/Nginx)
MC_REVERSE_PROXY=true

# The port clients will connect on (usually 443 with SSL)
MC_REVERSE_PROXY_PORT=443

# ┌──────────────────────────────────────────────┐
# │  🗄️ DATABASE                                 │
# └──────────────────────────────────────────────┘

# MongoDB password (REQUIRED — change this!)
MONGO_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ┌──────────────────────────────────────────────┐
# │  🔐 SECURITY                                 │
# └──────────────────────────────────────────────┘

# Session encryption key (leave empty to auto-generate on first run)
MC_SESSION_KEY=

# Allow new account self-registration (set to false in production)
MC_ALLOW_NEW_ACCOUNTS=false

# Allow iframe embedding (set to false to prevent clickjacking)
MC_ALLOW_FRAME=false

# Enable WebRTC for peer-to-peer connections
MC_WEBRTC=false

# ┌──────────────────────────────────────────────┐
# │  📧 EMAIL / SMTP (Optional)                  │
# └──────────────────────────────────────────────┘

# SMTP server hostname
MC_SMTP_HOST=

# SMTP server port (587 for TLS, 465 for SSL)
MC_SMTP_PORT=587

# Sender email address
MC_SMTP_FROM=

# SMTP authentication username
MC_SMTP_USER=

# SMTP authentication password
MC_SMTP_PASS=

# Use TLS for SMTP connection
MC_SMTP_TLS=true
